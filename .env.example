# ============================================================
# REYCE — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Stripe — récupérer sur https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret — récupérer sur https://dashboard.stripe.com/webhooks
# En développement avec Stripe CLI : stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# URL de base du site (sans slash final)
# En développement : http://localhost:3000
# En production    : https://reyce.fr
BASE_URL=http://localhost:3000

# Port du serveur (défaut : 3000)
PORT=3000
